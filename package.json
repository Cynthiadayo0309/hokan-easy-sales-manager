{
  "name": "hokan-easy-sales-manager",
  "version": "0.1.1",
  "description": "訪看かんたん売上管理",
  "author": "Hokan Easy Sales Manager",
  "license": "UNLICENSED",
  "private": true,
  "main": "dist/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "npm run native:electron && concurrently -k -n renderer,electron \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && npm run build:electron && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "native:electron": "node scripts/install-native.mjs electron",
    "native:node": "node scripts/install-native.mjs node",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.electron.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "npm run native:node && vitest run",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json",
    "build": "npm run typecheck && npm run test && npm run build:renderer && npm run build:electron",
    "dist": "npm run build && npm run native:electron && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win --x64"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "better-sqlite3": "^12.11.1",
    "pinia": "^2.3.1",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.10.7",
    "@vue/eslint-config-prettier": "^10.1.0",
    "@vue/eslint-config-typescript": "^14.3.0",
    "@vue/test-utils": "^2.4.6",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.18.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vitest": "^2.1.8",
    "vue-tsc": "^2.2.0",
    "wait-on": "^8.0.2"
  },
  "build": {
    "appId": "jp.hokan.easySalesManager",
    "productName": "訪看かんたん売上管理",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "icon": "build/icon.ico",
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "訪看かんたん売上管理"
    }
  }
}
